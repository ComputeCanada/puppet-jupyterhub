{
  "argv": [
    "<%= $prefix %>/bin/python",
    "-m",
    "ipykernel_launcher",
    "-f",
    "{connection_file}"
  ],
  "display_name": "<%= $display_name %>",
  "language": "python",
  "metadata": {
    "debugger": true
  },
  "env": <%= stdlib::to_json_pretty($env, undef, { 'indent' => '    ' }) %>
}
